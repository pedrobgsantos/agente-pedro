          "value": "Tarefas"
        },
        "options": {}
      },
      "id": "sheets-ler",
      "name": "Google Sheets - Ler",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1080,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "const { titulo, campo_norm, novo_valor } = $('Normalizar e Validar').first().json;\n\n// Normaliza texto: minúsculas, sem acentos, sem pontuação, espaços normalizados\nconst normTxt = s => s.toString()\n  .toLowerCase()\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .replace(/[^a-z0-9\\s]/g, '')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nconst tituloNorm = normTxt(titulo);\nconst todas = $input.all();\nconst encontradas = todas.filter(item => normTxt(item.json.titulo || '') === tituloNorm);\n\nif (encontradas.length === 0) {\n  return [{ json: { _ok: false, codigo: 'NAO_ENCONTRADO', mensagem: 'Tarefa não encontrada: \"' + titulo + '\". Verifique o nome exato.' } }];\n}\nif (encontradas.length > 1) {\n  return [{ json: { _ok: false, codigo: 'AMBIGUIDADE', mensagem: encontradas.length + ' tarefas encontradas com o título \"' + titulo + '\". Seja mais específico.' } }];\n}\n\nconst tarefa = encontradas[0].json;\nreturn [{ json: {\n  _ok: true,\n  id: tarefa.id,\n  titulo_encontrado: tarefa.titulo,\n  campo_norm,\n  novo_valor\n} }];"
      },
      "id": "resolver-tarefa",
      "name": "Resolver Tarefa",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        160
      ]
