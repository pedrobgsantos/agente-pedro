      "id": "trigger",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        200,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\nif (raw.input) {\n  const parsed = typeof raw.input === 'string' ? JSON.parse(raw.input) : raw.input;\n  return [{ json: parsed }];\n}\n\nreturn [{ json: raw }];"
      },
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $('Parse Input').item.json;\nconst titulo = (input.titulo || '').toString().trim();\nconst campoRaw = (input.campo || '').toString().trim().toLowerCase();\n// novo_valor vazio é permitido (limpa o campo) — só rejeita se ausente\nconst novoValor = (input.novo_valor !== undefined && input.novo_valor !== null)\n  ? input.novo_valor.toString()\n  : null;\n\nif (!titulo) return [{ json: { _ok: false, codigo: 'CAMPO_FALTANDO', mensagem: 'Campo obrigatório ausente: titulo.' } }];\nif (!campoRaw) return [{ json: { _ok: false, codigo: 'CAMPO_FALTANDO', mensagem: 'Campo obrigatório ausente: campo.' } }];\nif (novoValor === null) return [{ json: { _ok: false, codigo: 'CAMPO_FALTANDO', mensagem: 'Campo obrigatório ausente: novo_valor.' } }];\n\nconst mapa = {\n  status: 'status',\n  concluido: 'status',\n  concluida: 'status',\n  concluir: 'status',\n  prazo: 'prazo',\n  data: 'prazo',\n  'prazo final': 'prazo',\n  'data limite': 'prazo',\n  observacao: 'observacao',\n  'observação': 'observacao',\n  observacoes: 'observacao',\n  'observações': 'observacao',\n  obs: 'observacao'\n};\nconst campoNorm = mapa[campoRaw];\nif (!campoNorm) {\n  return [{ json: { _ok: false, codigo: 'CAMPO_INVALIDO', mensagem: 'Campo \"' + input.campo + '\" não é permitido. Use: status, prazo ou observacao.' } }];\n}\n\nreturn [{ json: {\n  _ok: true,\n  titulo,\n  campo_norm: campoNorm,\n  novo_valor: novoValor\n} }];"
      },
      "id": "normalizar-validar",
      "name": "Normalizar e Validar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "ok-check",
              "leftValue": "={{ $json._ok }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "validacao-ok",
      "name": "Validação OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        860,
        300
      ]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $env.SHEET_TAREFAS_ID }}"
        },
        "sheetName": {
          "__rl": true,
